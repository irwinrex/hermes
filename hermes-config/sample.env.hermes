# ── Hermes Agent API Keys ─────────────────────────────────────────────────────
# Copied to config/.env at runtime (config/.env is gitignored).
# Uncomment and fill in the keys you need.

# ── Primary API Keys ──

# OpenCode Zen API key (pay-as-you-go access to curated models)
# https://opencode.ai/auth
OPENCODE_ZEN_API_KEY=your-zen-api-key-here

# Google AI / Gemini API key
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# OpenRouter API key (broad model access)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ── Additional Provider Keys (uncomment as needed) ──

# OpenAI API key
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic API key
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Hugging Face token
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...

# DeepSeek API key
# https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...

# xAI API key
# https://console.x.ai/
# XAI_API_KEY=...

# NVIDIA NIM API key
# https://build.nvidia.com/
# NVIDIA_API_KEY=...

# ── Hermes Agent Runtime ──
HERMES_UID=502
HERMES_GID=20
HERMES_DASHBOARD=1
HERMES_DASHBOARD_TUI=1

# ── Dashboard Auth ──
# HERMES_USERNAME=admin
# HERMES_PASSWORD=your-password-here
# HERMES_API_KEY=your-api-key-here
HERMES_DASHBOARD_INSECURE=true
HERMES_SKIP_CONFIG_MIGRATION=1
